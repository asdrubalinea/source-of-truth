#!/bin/sh
# DESTRUCTIVE: destroys, formats and mounts the target disk per disks/tempest.nix.
# The device must be passed explicitly — there is no default, so an accidental
# bare run can't wipe the wrong disk.
set -eu
if [ "$#" -lt 1 ]; then
  echo "usage: $0 /dev/disk/by-id/<target>" >&2
  echo "refusing to run without an explicit target device (DESTROYS it)." >&2
  echo "tempest's NVMe is /dev/disk/by-id/nvme-Corsair_MP700_PRO_SE_A8WFB416001JKK" >&2
  exit 1
fi
sudo nix --experimental-features "nix-command flakes" run github:nix-community/disko/latest -- \
  --mode destroy,format,mount \
  --argstr device "$1" \
  ./disks/tempest.nix
